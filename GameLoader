class GameLoader {
    static load(data) {
        const model = new GameModel();

        model.rooms = this.loadRooms(data.rooms);
        model.items = this.loadItems(data.items);
        model.containers = this.loadContainers(data.containers);
        model.gatherers = this.loadGatherers(data.gatherers);
        model.doors = this.loadDoors(data.doors);

        this.linkWorld(model, data);

        model.player = new Player("room");

        return model;
    }
}

static loadRooms(roomsData) {
    const rooms = {};

    for (const id in roomsData) {
        rooms[id] = new Room(roomsData[id]);
    }

    return rooms;
}

static loadItems(itemsData) {
    const items = {};

    for (const id in itemsData) {
        items[id] = new Item(itemsData[id]);
    }

    return items;
}

static loadContainers(containersData) {
    const containers = {};

    for (const id in containersData) {
        containers[id] = new Container(containersData[id]);
    }

    return containers;
}

static loadGatherers(gatherersData) {
    const gatherers = {};

    for (const id in gatherersData) {
        gatherers[id] = new Gatherer(gatherersData[id]);
    }

    return gatherers;
}

static loadDoors(doorsData) {
    const doors = {};

    for (const id in doorsData) {
        doors[id] = new Door(doorsData[id]);
    }

    return doors;
}

static linkWorld(model, data) {
    for (const roomId in model.rooms) {
        const room = model.rooms[roomId];
        const roomData = data.rooms[roomId];

        room.contents = (roomData.contents || []).map(id => {
            return (
                model.items[id] ||
                model.containers[id] ||
                model.interactables[id] ||
                model.gatherers[id] ||
                model.doors[id]
            );
        }).filter(Boolean)
    }
}